AI_PROVIDER_KEY=
AI_PROVIDER_MODEL=anthropic/claude-sonnet-4.6
AI_PROVIDER=openrouter

# Clerk Authentication (optional - app runs in demo mode without these)
# Get these from https://dashboard.clerk.com
# Without these keys, the app runs in DEMO MODE with viewer-only permissions
CLERK_JWT_ISSUER_DOMAIN=
CLERK_SECRET_KEY=
VITE_CLERK_PUBLISHABLE_KEY=

# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=
VITE_CONVEX_SITE_URL=
VITE_CONVEX_URL=

# DEMO MODE: When CLERK_SECRET_KEY is not set:
# - All mutations are allowed with viewer role
# - Auth checks are bypassed
# - User profile shows as "Demo User"
#
# PRODUCTION MODE: Set all 3 Clerk vars above:
# - Full authentication required
# - Role-based access control enforced
# - Protected mutations require operator/admin roles
