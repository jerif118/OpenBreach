{
  "name": "deff-acc",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "auth:writes:validate": "node scripts/validate-auth-writes.ts",
    "build": "vite build && pnpm typecheck",
    "clean:hard": "node scripts/hard-clean.ts",
    "clean:soft": "node scripts/soft-clean.ts",
    "convex:codegen": "convex codegen",
    "convex:dev": "convex dev",
    "dashboard:data:validate": "node scripts/validate-dashboard-data-adapter.ts",
    "dashboard:filters:validate": "node scripts/validate-dashboard-filters.ts",
    "dashboard:list:validate": "node scripts/validate-dashboard-ranked-list.ts",
    "dashboard:map:validate": "node scripts/validate-dashboard-map.ts",
    "dashboard:shell:validate": "node scripts/validate-dashboard-shell.ts",
    "dashboard:verify": "node scripts/validate-dashboard-verification.ts",
    "dev": "vite dev",
    "fix:oxfmt": "oxfmt --write",
    "fixtures:validate": "node scripts/validate-fixtures.ts && node scripts/validate-municipality-seed.ts",
    "lint:oxfmt": "oxfmt --check",
    "municipalities:detail:validate": "node scripts/validate-municipality-detail.ts",
    "municipalities:list:validate": "node scripts/validate-municipality-list.ts",
    "municipalities:seed": "convex run municipalities:seed \"$(node scripts/municipality-seed-args.ts)\"",
    "municipalities:seed:args": "node scripts/municipality-seed-args.ts",
    "municipalities:validate": "node scripts/validate-municipality-seed.ts",
    "preview": "vite preview",
    "report:ai-provider": "node scripts/validate-report-ai-provider.ts",
    "report:batch": "node scripts/validate-report-batch.ts",
    "report:generate": "node scripts/generate-reports.ts",
    "report:generate:all": "node scripts/generate-reports.ts --all",
    "report:generate:validate": "node scripts/validate-report-generation.ts",
    "report:pdfs": "node scripts/validate-report-pdfs.ts",
    "report:persist:args": "node scripts/report-convex-args.ts",
    "report:persist:fixture": "node scripts/report-fixture-persist-args.ts | node scripts/persist-via-convex.ts reports:seedFromFixture",
    "report:persistence:validate": "node scripts/validate-report-persistence.ts",
    "report:select": "node scripts/validate-report-selection.ts",
    "report:smoke": "node scripts/report-smoke.ts",
    "risk:fixture": "node scripts/export-enriched-scan-fixture.ts",
    "risk:persist": "node scripts/risk-convex-args.ts | node scripts/persist-via-convex.ts scanResults:upsertEnrichedMany",
    "risk:persist:args": "node scripts/risk-convex-args.ts",
    "risk:validate": "node scripts/validate-risk-scoring.ts",
    "scanner:fixture": "node scripts/export-scan-fixture.ts",
    "scanner:persist": "node scripts/scan-convex-args.ts | node scripts/persist-via-convex.ts rawScanResults:upsertMany",
    "scanner:persist:args": "node scripts/scan-convex-args.ts",
    "scanner:persistence:validate": "node scripts/validate-scan-persistence.ts",
    "scanner:validate": "node scripts/validate-scanner.ts",
    "start": "node .output/server/index.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clerk/tanstack-react-start": "1.2.4",
    "@mastra/core": "1.34.0",
    "@tanstack/ai": "0.17.0",
    "@tanstack/ai-openrouter": "0.9.0",
    "@tanstack/react-router": "^1.170.1",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-start": "^1.168.1",
    "convex": "1.39.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.5.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "nitro": "^3.0.260311-beta",
    "oxfmt": "0.50.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.0"
  },
  "engines": {
    "node": "24.15.0"
  },
  "packageManager": "pnpm@11.1.2+sha224.6d287705d0efa6c2ba7a74795dc72a7800f64840f2bc0961cedba029"
}
