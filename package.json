    "@vitejs/plugin-react": "6.0.2",
    "nitro": "3.0.260429-beta",
    "npm-run-all2": "8.0.4",
    "oxfmt": "0.50.0",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vite": "8.0.13"
